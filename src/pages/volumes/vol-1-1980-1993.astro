---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const outline = [
  { year: 1980, titleZh: '重新起步的年代，未来还在远处', status: 'NEEDS UPGRADE' },
  { year: 1981, titleZh: '机器开始拥有个人尺寸', status: 'DRAFTED' },
  { year: 1982, titleZh: '电脑开始被社会看见', status: 'DRAFTED' },
  { year: 1983, titleZh: '屏幕开始学会与人对话', status: 'DRAFTED' },
  { year: 1984, titleZh: '电脑开始像一件普通人敢靠近的东西', status: 'DRAFTED' },
  { year: 1985, titleZh: '电脑开始进入普通工作的想象', status: 'DRAFTED' },
  { year: 1986, titleZh: '电脑开始改写办公室的秩序', status: 'DRAFTED' },
  { year: 1987, titleZh: '电脑开始进入联网工作的前夜', status: 'DRAFTED' },
  { year: 1988, titleZh: '网络社会第一次露出它的影子', status: 'DRAFTED' },
  { year: 1989, titleZh: '世界开始学着在网络边缘生活', status: 'DRAFTED' },
  { year: 1990, titleZh: '世界开始按网页的方式组织自己', status: 'DRAFTED' },
  { year: 1991, titleZh: '网络开始从工具系统变成公共空间', status: 'DRAFTED' },
  { year: 1992, titleZh: '网络开始准备进入大众视野', status: 'DRAFTED' },
  { year: 1993, titleZh: '网络第一次长出大众入口', status: 'DRAFTED' },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={`${SITE_TITLE} · Volume I`} description="Volume I navigation and writing status." />
    <style>
      main { width: 960px; }
      .lead { color: var(--gray); line-height: 1.7; }
      .table { margin-top: 1rem; border: 1px solid rgba(var(--gray), 18%); border-radius: 12px; overflow: hidden; }
      .row { display:grid; grid-template-columns: 100px 1fr 150px; gap: 12px; padding: 12px 14px; border-top: 1px solid rgba(var(--gray), 12%); background: #fff; }
      .row:first-child { border-top: 0; }
      .hdr { background: rgba(var(--gray), 6%); font-weight: 700; }
      .muted { color: var(--gray); }
      .ok { color:#0f766e; font-weight:700; }
      .warn { color:#b45309; font-weight:700; }
      a { text-decoration:none; }
      .links { margin-top: 1rem; display:flex; gap: 1rem; flex-wrap: wrap; }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <h1>第一卷：数字前夜（1980—1993）</h1>
      <p class="lead">
        副标题：从大机器时代的尾声，到网络长出大众入口。
        <br />
        这是《地球文明0.5编年史》第一卷的导航页，展示卷结构、章节状态与已发布入口。
      </p>

      <div class="links">
        <a href="/blog/2026-03-06-volume-1-digital-eve-progress/">查看第一卷进度说明</a>
        <a href="/blog/2026-03-06-now-records-issue-1/">查看“当下记录”第一辑</a>
        <a href="/blog/2026-03-06-chapter-1995-internet-enters-the-center/">查看 1995 章节样稿</a>
      </div>

      <div class="table">
        <div class="row hdr">
          <div>Year</div>
          <div>章节标题</div>
          <div>Status</div>
        </div>
        {outline.map(item => (
          <div class="row">
            <div class="muted">{item.year}</div>
            <div>{item.titleZh}</div>
            <div class={item.status === 'NEEDS UPGRADE' ? 'warn' : 'ok'}>{item.status}</div>
          </div>
        ))}
      </div>
    </main>
    <Footer />
  </body>
</html>
